# Local SQLite database file
DATABASE_FILE=./local.db

# better-auth secret — generate with `openssl rand -base64 32` or any 32+ random chars
BETTER_AUTH_SECRET=replace-with-long-random-string-at-least-32-chars

# Base URL for the app (used by better-auth for callbacks / email links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Resend — not used until TU-9
RESEND_API_KEY=
