# Neon Postgres connection string (includes sslmode=require)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# better-auth secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=replace-with-long-random-string-at-least-32-chars

# Base URL for the app (used by better-auth for callbacks / email links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Resend — transactional email (booking confirmations, etc.)
RESEND_API_KEY=
# Optional: override the From address. Defaults to tutor. <onboarding@resend.dev>
# (Resend's shared sender; only delivers to your verified account address).
# Once a custom domain is verified in Resend, set it here.
EMAIL_FROM=
# Teacher identity used in confirmation emails. Defaults applied if unset.
TEACHER_NAME=
TEACHER_ADDRESS=
